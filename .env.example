APP_ENV=development
APP_NAME=Eidolon
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
CORS_ORIGINS=
ENABLE_DEBUG_ROUTES=false
# In Codespaces, browser requests cannot rely on localhost.
# Example:
# WEB_ORIGIN=https://<codespace-name>-3000.app.github.dev
# CORS_ORIGINS=https://<codespace-name>-3000.app.github.dev

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eidolon
POSTGRES_USER=eidolon
POSTGRES_PASSWORD=eidolon_dev_password
DATABASE_URL=postgresql+asyncpg://eidolon:eidolon_dev_password@localhost:5432/eidolon

# Generate a private value with: openssl rand -hex 32
# Required size: 32-4096 UTF-8 bytes. The placeholder is development-only.
JWT_SECRET=change-me-in-real-env-use-32-plus-bytes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_BLOCK_SECONDS=900
REGISTRATION_MAX_ATTEMPTS=5
REGISTRATION_ATTEMPT_WINDOW_SECONDS=900
REGISTRATION_BLOCK_SECONDS=900
# Use REFRESH_COOKIE_SECURE=true for Codespaces HTTPS and every production deployment.

LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.8
LLM_MAX_OUTPUT_TOKENS=1200
LLM_TIMEOUT_SECONDS=45
LLM_CONTEXT_BUDGET_TOKENS=8000
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_SECONDS=0.5
# Optional fallback. Never configure mock as fallback for a live provider.
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=

# Explicit development/test alternative:
# LLM_PROVIDER=mock
# Local production alternative:
# LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

ENABLE_SCHEDULER=true
SCHEDULER_INTERVAL_SECONDS=60
SCHEDULER_JOB_LIMIT=10
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_BASE_SECONDS=30
PROACTIVE_INACTIVITY_HOURS=24
PROACTIVE_COOLDOWN_HOURS=24

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# For Codespaces frontend builds/dev server:
# NEXT_PUBLIC_API_BASE_URL=https://<codespace-name>-8000.app.github.dev

BACKUP_DIR=backups
