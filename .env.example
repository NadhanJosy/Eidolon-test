# Eidolon backend configuration. Copy to .env for local development only.
# Cloud Run variables are configured in Cloud Run/Secret Manager, not committed files.

APP_ENV=development
APP_NAME=Eidolon
ENABLE_DEBUG_ROUTES=false

# Browser origin allowed to send credentialed requests to the API.
WEB_ORIGIN=http://localhost:3000
# Optional comma-separated additional exact origins (no wildcard with credentials).
CORS_ORIGINS=

# Local Docker Compose PostgreSQL. Production must replace this with the Supabase
# Session pooler URL from Connect -> Session pooler (port 5432). URL-encode the password.
DATABASE_URL=postgresql+asyncpg://eidolon:eidolon_dev_password@localhost:5432/eidolon
# Production shape (placeholder only):
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=0
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=300

# Generate a production value with: openssl rand -hex 32
# Required size: 32-4096 UTF-8 bytes. This placeholder is rejected in production.
JWT_SECRET=change-me-in-real-env-use-32-plus-bytes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_BLOCK_SECONDS=900
REGISTRATION_MAX_ATTEMPTS=5
REGISTRATION_ATTEMPT_WINDOW_SECONDS=900
REGISTRATION_BLOCK_SECONDS=900

# Mock is deterministic and allowed only for development/tests.
# Cloud Run production must set LLM_PROVIDER=groq and provide GROQ_API_KEY.
LLM_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.8
LLM_MAX_OUTPUT_TOKENS=1200
LLM_TIMEOUT_SECONDS=45
LLM_CONTEXT_BUDGET_TOKENS=8000
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_SECONDS=0.5
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
COGNITION_MODE=selective
COGNITION_MAX_OUTPUT_TOKENS=700

# Ollama remains a development option, but is rejected by this production profile.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

ENABLE_SCHEDULER=true
SCHEDULER_INTERVAL_SECONDS=60
SCHEDULER_JOB_LIMIT=10
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_BASE_SECONDS=30
PROACTIVE_INACTIVITY_HOURS=24
PROACTIVE_COOLDOWN_HOURS=24

# Cloud Run injects PORT. Do not add PORT to Cloud Run environment variables.
# The production image defaults to 8080 only when run outside Cloud Run.

BACKUP_DIR=backups
