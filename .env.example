APP_ENV=development
APP_NAME=Eidolon
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
CORS_ORIGINS=
ENABLE_DEBUG_ROUTES=false
# In Codespaces, browser requests cannot rely on localhost.
# Example:
# WEB_ORIGIN=https://<codespace-name>-3000.app.github.dev
# CORS_ORIGINS=https://<codespace-name>-3000.app.github.dev

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eidolon
POSTGRES_USER=eidolon
POSTGRES_PASSWORD=eidolon_dev_password
DATABASE_URL=postgresql+asyncpg://eidolon:eidolon_dev_password@localhost:5432/eidolon

JWT_SECRET=change-me-in-real-env
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

LLM_PROVIDER=mock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120

ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_SECONDS=60
SCHEDULER_JOB_LIMIT=10
PROACTIVE_INACTIVITY_HOURS=24
PROACTIVE_COOLDOWN_HOURS=24

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# For Codespaces frontend builds/dev server:
# NEXT_PUBLIC_API_BASE_URL=https://<codespace-name>-8000.app.github.dev

BACKUP_DIR=backups
