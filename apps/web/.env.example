# Public browser configuration only. Never place DATABASE_URL, GROQ_API_KEY,
# JWT_SECRET, or any other backend secret in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Cloudflare Pages must set this at build time to the HTTPS Cloud Run service URL.
# Example placeholder:
# NEXT_PUBLIC_API_BASE_URL=https://eidolon-api-<project-number>.<region>.run.app
